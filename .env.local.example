# Supabase設定
# ⚠ 実際の値をここに書かないこと。本ファイルはサンプルでありリポジトリにコミットされます。
# 実値は .env.local に記述してください（.env.local は .gitignore に含まれています）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# サイト設定
NEXT_PUBLIC_SITE_NAME=企業研修LMS
NEXT_PUBLIC_SITE_URL=https://lms.example.com

# メール設定
NEXT_PUBLIC_EMAIL_FROM=noreply@example.com

# 開発環境設定
NODE_ENV=development
